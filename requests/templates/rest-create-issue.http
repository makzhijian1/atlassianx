@jiraSiteUrl = https://your-domain.atlassian.net
@jiraEmail = user@example.com
@jiraApiToken = replace_me
@jiraProjectKey = EXAMPLE
@issueType = Task

### REST: Create a basic issue
POST {{jiraSiteUrl}}/rest/api/3/issue
Authorization: Basic {{jiraEmail}} {{jiraApiToken}}
Accept: application/json
Content-Type: application/json

{
  "fields": {
    "project": {
      "key": "{{jiraProjectKey}}"
    },
    "issuetype": {
      "name": "{{issueType}}"
    },
    "summary": "Order processing system should validate payment before fulfillment",
    "description": {
      "type": "doc",
      "version": 1,
      "content": [
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Background"
            }
          ]
        },
        {
          "type": "paragraph",
          "content": [
            {
              "type": "text",
              "text": "Orders can currently move toward fulfillment before the payment state is confirmed."
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Requirements"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Validate payment status before fulfillment starts."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Block fulfillment for unpaid or failed-payment orders."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Expose a clear failure reason for operations users."
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "heading",
          "attrs": {
            "level": 2
          },
          "content": [
            {
              "type": "text",
              "text": "Acceptance Criteria"
            }
          ]
        },
        {
          "type": "bulletList",
          "content": [
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Paid orders can proceed to fulfillment."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Unpaid orders are blocked from fulfillment."
                    }
                  ]
                }
              ]
            },
            {
              "type": "listItem",
              "content": [
                {
                  "type": "paragraph",
                  "content": [
                    {
                      "type": "text",
                      "text": "Operations users can see why fulfillment was blocked."
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  }
}
