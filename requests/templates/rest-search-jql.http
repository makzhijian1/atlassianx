@jiraSiteUrl = https://your-domain.atlassian.net
@jiraEmail = user@example.com
@jiraApiToken = replace_me
@jiraProjectKey = EXAMPLE
@jql = project = EXAMPLE ORDER BY updated DESC

### REST: Get issues by JQL
POST {{jiraSiteUrl}}/rest/api/3/search/jql
Authorization: Basic {{jiraEmail}} {{jiraApiToken}}
Accept: application/json
Content-Type: application/json

{
  "jql": "{{jql}}",
  "fields": [
    "summary",
    "status",
    "issuetype",
    "project",
    "parent",
    "updated"
  ],
  "maxResults": 50
}
