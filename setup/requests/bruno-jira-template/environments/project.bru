vars {
  JIRA_PROJECT_URL: https://example.atlassian.net/jira/software/projects/EXAMPLE
  JIRA_SITE_URL: https://example.atlassian.net
  JIRA_PROJECT_KEY: EXAMPLE
  JIRA_EMAIL: user@example.com
  JIRA_API_TOKEN: replace_me
  JIRA_CLOUD_ID: replace_me
  GRAPHQL_URL: https://api.atlassian.com/graphql
  ISSUE_KEY: EXAMPLE-1
  EPIC_KEY: EXAMPLE-1
  ISSUE_TYPE: Task
  JQL: project = EXAMPLE ORDER BY updated DESC
}
