meta {
  name: Get Epic Issues
  type: http
  seq: 2
}

post {
  url: {{JIRA_SITE_URL}}/rest/api/3/search/jql
  body: json
  auth: basic
}

headers {
  Accept: application/json
  Content-Type: application/json
}

auth:basic {
  username: {{JIRA_EMAIL}}
  password: {{JIRA_API_TOKEN}}
}

body:json {
  {
    "jql": "parent = {{EPIC_KEY}} ORDER BY created ASC",
    "fields": [
      "summary",
      "status",
      "issuetype",
      "parent"
    ],
    "maxResults": 50
  }
}
